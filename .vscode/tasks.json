{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npu:sim:check-tools",
      "type": "shell",
      "command": "iverilog -V; vvp -V",
      "linux": {
        "command": "bash -lc 'if command -v iverilog >/dev/null 2>&1 && command -v vvp >/dev/null 2>&1; then iverilog -V; vvp -V; else \"$HOME/.local/micromamba/envs/fpga-sim/bin/iverilog\" -V; \"$HOME/.local/micromamba/envs/fpga-sim/bin/vvp\" -V; fi'"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "problemMatcher": []
    },
    {
      "label": "run:npu:iverilog:one-click",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File sim/NPU/run_iverilog_npu.ps1",
      "linux": {
        "command": "bash sim/NPU/run_iverilog_npu.sh"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "run:npu:iverilog:one-click:wave",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File sim/NPU/run_iverilog_npu.ps1 -Wave",
      "linux": {
        "command": "bash sim/NPU/run_iverilog_npu.sh --wave"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run:npu:cluster:iverilog:one-click",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File sim/NPU/run_iverilog_npu_cluster.ps1",
      "linux": {
        "command": "bash sim/NPU/run_iverilog_npu_cluster.sh"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run:npu:cluster:iverilog:one-click:wave",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File sim/NPU/run_iverilog_npu_cluster.ps1 -Wave",
      "linux": {
        "command": "bash sim/NPU/run_iverilog_npu_cluster.sh --wave"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run:npu:csr:iverilog:one-click",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File sim/NPU/run_iverilog_npu_csr.ps1",
      "linux": {
        "command": "bash sim/NPU/run_iverilog_npu_csr.sh"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run:npu:csr:iverilog:one-click:wave",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File sim/NPU/run_iverilog_npu_csr.ps1 -Wave",
      "linux": {
        "command": "bash sim/NPU/run_iverilog_npu_csr.sh --wave"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run:npu:wave:open",
      "type": "shell",
      "command": "gtkwave \"${workspaceFolder}/picorv32-main/picorv32-main/tb_npu_core_tile_4x4.vcd\"",
      "linux": {
        "command": "bash -lc 'if command -v gtkwave >/dev/null 2>&1; then gtkwave \"${workspaceFolder}/picorv32-main/picorv32-main/tb_npu_core_tile_4x4.vcd\"; else \"$HOME/.local/micromamba/envs/fpga-sim/bin/gtkwave\" \"${workspaceFolder}/picorv32-main/picorv32-main/tb_npu_core_tile_4x4.vcd\"; fi'"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "problemMatcher": []
    },
    {
      "label": "run:npu:csr:wave:open",
      "type": "shell",
      "command": "gtkwave \"${workspaceFolder}/picorv32-main/picorv32-main/tb_npu_csr_if.vcd\"",
      "linux": {
        "command": "bash -lc 'if command -v gtkwave >/dev/null 2>&1; then gtkwave \"${workspaceFolder}/picorv32-main/picorv32-main/tb_npu_csr_if.vcd\"; else \"$HOME/.local/micromamba/envs/fpga-sim/bin/gtkwave\" \"${workspaceFolder}/picorv32-main/picorv32-main/tb_npu_csr_if.vcd\"; fi'"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "problemMatcher": []
    },
    {
      "label": "run:npu:cluster:wave:open",
      "type": "shell",
      "command": "gtkwave \"${workspaceFolder}/picorv32-main/picorv32-main/tb_npu_core_cluster.vcd\"",
      "linux": {
        "command": "bash -lc 'if command -v gtkwave >/dev/null 2>&1; then gtkwave \"${workspaceFolder}/picorv32-main/picorv32-main/tb_npu_core_cluster.vcd\"; else \"$HOME/.local/micromamba/envs/fpga-sim/bin/gtkwave\" \"${workspaceFolder}/picorv32-main/picorv32-main/tb_npu_core_cluster.vcd\"; fi'"
      },
      "options": {
        "cwd": "${workspaceFolder}/picorv32-main/picorv32-main"
      },
      "problemMatcher": []
    },
    {
      "label": "run:npu:vivado:cleanup",
      "type": "shell",
      "command": "$ErrorActionPreference='SilentlyContinue'; try { Get-Process xsim,xsimk,xelab,xvlog | Stop-Process -Force } catch {}; try { Remove-Item -Recurse -Force \"${workspaceFolder}/picorv32-main/picorv32-main/.sim/xsim_npu\" } catch {}; try { Remove-Item -Recurse -Force \"${workspaceFolder}/picorv32-main/picorv32-main/.sim/xsim_npu_cluster\" } catch {}; exit 0",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "run:npu:vivado:one-click:batch",
      "type": "shell",
      "command": "\"${input:vivadoCmd}\" -mode batch -source \"${workspaceFolder}/picorv32-main/picorv32-main/sim/NPU/run_vivado_npu.tcl\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "run:npu:vivado:cleanup"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run:npu:vivado:one-click:gui",
      "type": "shell",
      "command": "\"${input:vivadoCmd}\" -source \"${workspaceFolder}/picorv32-main/picorv32-main/sim/NPU/run_vivado_npu.tcl\" -tclargs gui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "run:npu:vivado:cleanup"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run:npu:cluster:vivado:one-click:batch",
      "type": "shell",
      "command": "\"${input:vivadoCmd}\" -mode batch -source \"${workspaceFolder}/picorv32-main/picorv32-main/sim/NPU/run_vivado_npu_cluster.tcl\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "run:npu:vivado:cleanup"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run:npu:cluster:vivado:one-click:gui",
      "type": "shell",
      "command": "\"${input:vivadoCmd}\" -source \"${workspaceFolder}/picorv32-main/picorv32-main/sim/NPU/run_vivado_npu_cluster.tcl\" -tclargs gui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "run:npu:vivado:cleanup"
      ],
      "group": "test",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "vivadoCmd",
      "type": "promptString",
      "description": "Absolute path to Vivado launcher (vivado.bat)",
      "default": "D:/FPGA/AMD_FPGA_TOOLS/2025.2/Vivado/bin/vivado.bat"
    }
  ]
}
